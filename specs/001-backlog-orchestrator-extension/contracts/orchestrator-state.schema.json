{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spec-kit-empty-orchestrator/contracts/orchestrator-state.schema.json",
  "title": "OrchestratorState",
  "description": "Top-level persisted run state. Single-writer (the Lead). Atomic-replace on write.",
  "type": "object",
  "required": ["schema_version", "run_id", "created_at", "updated_at", "config_snapshot", "features", "counters", "events_log_path"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "config_snapshot": {
      "$ref": "orchestrate-config.schema.json"
    },
    "features": {
      "type": "array",
      "items": { "$ref": "#/$defs/feature" }
    },
    "counters": {
      "type": "object",
      "required": ["queued", "running", "blocked", "failed", "complete"],
      "additionalProperties": false,
      "properties": {
        "queued": { "type": "integer", "minimum": 0 },
        "running": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "complete": { "type": "integer", "minimum": 0 }
      }
    },
    "events_log_path": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "feature": {
      "type": "object",
      "required": [
        "id", "title", "original_title", "description",
        "worktree_path", "branch_name", "spec_file_path",
        "phase", "status", "last_payload", "pending_clarification",
        "created_at", "updated_at", "target_commit"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "title": { "type": "string", "minLength": 1 },
        "original_title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "worktree_path": { "type": "string", "minLength": 1 },
        "branch_name": { "type": "string", "minLength": 1 },
        "spec_file_path": { "type": "string", "minLength": 1 },
        "phase": { "type": "string", "enum": ["ba", "dev", "merge", "done"] },
        "status": { "type": "string", "enum": ["queued", "running", "blocked", "failed", "complete"] },
        "last_payload": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "agent-payload.schema.json" }
          ]
        },
        "pending_clarification": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["question", "context"],
              "additionalProperties": false,
              "properties": {
                "question": { "type": "string" },
                "context": { "type": "string" },
                "options": { "type": "array", "items": { "type": "string" } },
                "correlation_id": { "type": "string" }
              }
            }
          ]
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "target_commit": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^[0-9a-f]{7,40}$" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "blocked" } } },
          "then": {
            "properties": {
              "pending_clarification": { "type": "object" },
              "phase": { "const": "ba" }
            }
          }
        },
        {
          "if": { "properties": { "phase": { "const": "done" } } },
          "then": {
            "properties": {
              "status": { "const": "complete" },
              "target_commit": { "type": "string" }
            }
          }
        }
      ]
    }
  }
}
